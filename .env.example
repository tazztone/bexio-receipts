# bexio-receipts Environment Variables Template

# Get your API token at: https://office.bexio.com/index.php/admin/apiTokens
BEXIO_API_TOKEN=your_bexio_token
BEXIO_BASE_URL=https://api.bexio.com

# OCR Settings
OCR_ENGINE=glm-ocr  # Options: paddleocr, glm-ocr
OCR_CONFIDENCE_THRESHOLD=0.85  # Note: Currently only enforced for paddleocr engine

# If using GLM-OCR (via Ollama)
# Download Ollama at: https://ollama.com
GLM_OCR_MODEL=glm-ocr
GLM_OCR_URL=http://localhost:11434

# LLM Settings (for extraction)
LLM_PROVIDER=ollama  # Options: ollama, openai
LLM_MODEL=qwen3.5:9b

# Default bexio accounts (Required for expense creation)
# You can find these IDs in your bexio account settings or via the API
DEFAULT_BOOKING_ACCOUNT_ID=123
DEFAULT_BANK_ACCOUNT_ID=456

# Ingestion Settings
DATABASE_PATH=processed_receipts.db
REVIEW_DIR=./review_queue
MAX_RECEIPT_AGE_DAYS=365
REVIEW_USERNAME=admin
REVIEW_PASSWORD=admin
# Generate a secure key: openssl rand -hex 32
SECRET_KEY=change-me-in-production-for-session-security

# Telegram Bot (Optional)
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_ALLOWED_USERS=1234567,8901234  # Comma-separated list of user IDs

# Google Drive (Optional)
# Setup a Service Account in Google Cloud Console: https://console.cloud.google.com
GDRIVE_CREDENTIALS_FILE=service_account.json
GDRIVE_FOLDER_ID=your_folder_id
GDRIVE_POLL_INTERVAL=60
GDRIVE_PROCESSED_FOLDER_ID=optional_archive_folder_id
