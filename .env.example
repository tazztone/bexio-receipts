# bexio-receipts Environment Variables Template

# Application Environment (Set to 'production' for strict security checks)
ENV=development
# Set to true to run OCR/LLM locally without a Bexio token
OFFLINE_MODE=false
# Master write gate. Set to true only when ready to book real entries in Bexio.
BEXIO_PUSH_ENABLED=false

# Get your Personal Access Token at: https://office.bexio.com/index.php/admin/apiTokens
# Personal Access Token — no redirect URL needed (that's for OAuth2 only)
BEXIO_API_TOKEN=your_bexio_token
BEXIO_BASE_URL=https://api.bexio.com

# OCR Settings
OCR_ENGINE=glm-ocr  # Options: paddleocr, glm-ocr
OCR_CONFIDENCE_THRESHOLD=0.85  # Note: Currently only enforced for paddleocr engine

# If using GLM-OCR (via Ollama)
# Download Ollama at: https://ollama.com
# These can be different if running OCR and LLM on separate hosts
GLM_OCR_MODEL=glm-ocr
GLM_OCR_URL=http://localhost:11434

# LLM Settings (for extraction)
LLM_PROVIDER=ollama  # Options: ollama, openai
# Supports Ollama tag suffixes, e.g. qwen3.5:9b-q4_K_M (4-bit, ~6GB RAM)
LLM_MODEL=qwen3.5:9b
# OLLAMA_URL can be separate from GLM_OCR_URL
OLLAMA_URL=http://localhost:11434
# OPENAI_API_KEY=sk-...

# Default bexio accounts (Required for expense creation)
# You can find these IDs in your bexio account settings or via the API
DEFAULT_BOOKING_ACCOUNT_ID=123
DEFAULT_BANK_ACCOUNT_ID=456
DEFAULT_VAT_RATE=8.1
DEFAULT_PAYMENT_TERMS_DAYS=30

# Ingestion Settings
DATABASE_PATH=processed_receipts.db
INBOX_PATH=./inbox
REVIEW_DIR=./review_queue
MAX_RECEIPT_AGE_DAYS=365

# Security & Dashboard
# 🚨 REQUIRED: Dashboard and Review Queue login credentials
REVIEW_USERNAME=admin
# 🚨 SECURITY WARNING: MUST BE SET IN PRODUCTION
# This password protects your dashboard and receipt review queue.
# If ENV=production, the literal string 'password' will be rejected.
REVIEW_PASSWORD=your_secure_password

# Multi-user support (Optional JSON dictionary)
# REVIEW_USERS={"user1": "pass1", "user2": "pass2"}

# Generate a secure key: openssl rand -hex 32
SECRET_KEY=change-me-in-production-for-session-security

# --- Optional Integrations ---

# Email Ingestion (Optional)
# IMAP_SERVER=imap.gmail.com
# IMAP_USER=your_email@gmail.com
# IMAP_PASSWORD=your_app_password
# IMAP_FOLDER=INBOX
# IMAP_POLL_INTERVAL=300

# Telegram Bot (Optional)
# Create a bot via @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_ALLOWED_USERS=1234567,8901234  # Comma-separated list of user IDs

# Google Drive (Optional)
# Setup a Service Account in Google Cloud Console: https://console.cloud.google.com
# GDRIVE_CREDENTIALS_FILE=service_account.json
# GDRIVE_TOKEN_PATH=token.json
# GDRIVE_FOLDER_ID=your_folder_id
# GDRIVE_POLL_INTERVAL=60
# GDRIVE_PROCESSED_FOLDER_ID=optional_archive_folder_id
